# CRM Shopify Admin REST API (copy into your .env)
# Base URL used by the app: https://{SHOPIFY_STORE_URL}/admin/api/{SHOPIFY_API_VERSION}/
# Store URL: hostname only, e.g. my-shop.myshopify.com
SHOPIFY_STORE_URL=
# Private / custom app Admin API access token
SHOPIFY_ACCESS_TOKEN=
# Optional fallbacks (legacy)
SHOPIFY_API_KEY=
SHOPIFY_PASSWORD=

# API version path (see Shopify API release notes)
SHOPIFY_API_VERSION=2025-01

# HTTP client (Guzzle)
SHOPIFY_HTTP_TIMEOUT=120
SHOPIFY_CONNECT_TIMEOUT=15

# Rate limiting: pause when bucket use >= threshold * max (see X-Shopify-Shop-Api-Call-Limit)
SHOPIFY_RATE_LIMIT_THRESHOLD=0.85
SHOPIFY_RATE_LIMIT_PAUSE=2

# Retries for 429, 5xx, and connection errors
SHOPIFY_MAX_RETRIES=5

# CRM: assignee user id for auto follow-ups when a NEW Shopify order is synced (optional)
CRM_SHOPIFY_NEW_ORDER_ASSIGNEE_ID=

# CRM: create a `customers` row when syncing Shopify customers with a valid email (default true)
CRM_SHOPIFY_AUTO_CREATE_CUSTOMERS=true
