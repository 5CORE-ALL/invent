# Temu API – Title Update Configuration
# Add these to your .env file for Temu goods/title updates

# Use partial update (recommended – only sends changed fields)
TEMU_GOODS_UPDATE_TYPE=bg.local.goods.partial.update

# SKU list field name (skuList or skuInfoList depending on API version)
TEMU_SKU_LIST_FIELD=skuInfoList

# Required Temu credentials (should already exist)
# TEMU_APP_KEY=your_app_key
# TEMU_SECRET_KEY=your_secret_key
# TEMU_ACCESS_TOKEN=your_access_token
